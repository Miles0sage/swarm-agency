[20.065655, "o", "\r\n\u001b[32m╭────────────────────────────────────────────────────────────────────────────────────────╮\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                        \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m   \u001b[1;32m                         YES  —  Medium confidence (71%)                          \u001b[0m   \u001b[32m│\u001b[0m\r\n\u001b[32m│\u001b[0m                                                                                        \u001b[32m│\u001b[0m\r\n\u001b[32m╰────────────────────────────────────────────────────────────────────────────────────────╯\u001b[0m\r\n"]
[20.067237, "o", "  Leaning YES. \u001b[1;36m4\u001b[0m/\u001b[1;36m5\u001b[0m agents agree \u001b[1m(\u001b[0mmedium confidence\u001b[1m)\u001b[0m, but there are counterarguments worth \r\nconsidering.\r\n"]
[20.067387, "o", "\r\n"]
[20.067996, "o", "\u001b[92m────────────────────────────────────────── \u001b[0m\u001b[1mWhy\u001b[0m\u001b[92m ───────────────────────────────────────────\u001b[0m\r\n"]
[20.068396, "o", "  \u001b[1;36m1\u001b[0m\u001b[1m.\u001b[0m Open source is the dominant GTM for dev tools in \u001b[1;36m2026\u001b[0m.\r\n"]
[20.068744, "o", "  \u001b[1;36m2\u001b[0m\u001b[1m.\u001b[0m \u001b[1;36m3\u001b[0m closed-source competitors = we're the only OSS option.\r\n"]
[20.06906, "o", "  \u001b[1;36m3\u001b[0m\u001b[1m.\u001b[0m Use AGPL or BSL license to prevent cloud provider cloning.\r\n"]
[20.069135, "o", "\r\n"]
[20.069692, "o", "\u001b[92m──────────────────────────────────────── \u001b[0m\u001b[1;31mTop Risk\u001b[0m\u001b[92m ────────────────────────────────────────\u001b[0m\r\n"]
[20.070245, "o", "  \u001b[31mOSS success stories are survivorship bias. Hashicorp re-licensed, Elastic sued AWS, \u001b[0m\r\n\u001b[31mRedis went source-available. Open source is giving away your product to companies that \u001b[0m"]
[20.070317, "o", "\r\n\u001b[31mwill outspend you.\u001b[0m\r\n"]
[20.07036, "o", "\r\n"]
[20.070906, "o", "  \u001b[32m████████████████████████████████\u001b[0m\u001b[31m████████\u001b[0m  \u001b[1;32m4\u001b[0m for \u001b[35m/\u001b[0m \u001b[1;31m1\u001b[0m against \u001b[35m/\u001b[0m \u001b[1;33m0\u001b[0m undecided\r\n"]
