[0.104841, "o", "\r\n\u001b[94m├──────────────────┼──────────────────────┼──────────────────┼───────────┼────────────────┼─────────────────────────────────────────────────\u001b[0m\r\n\u001b[94m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mNumbersCruncher \u001b[0m\u001b[1;36m \u001b[0m\u001b[94m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mCFO                 \u001b[0m\u001b[2m \u001b[0m\u001b[94m│\u001b[0m \u001b[92mqwen3-coder-plus\u001b[0m \u001b[94m│\u001b[0m  \u001b[1;33mNEUTRAL\u001b[0m  \u001b[94m│\u001b[0m \u001b[31m████░░░░░░\u001b[0m 45% \u001b[94m│\u001b[0m Break-even requires 2,400 paid conversions      \r\n\u001b[94m├──────────────────┼──────────────────────┼──────────────────┼───────────┼────────────────┼─────────────────────────────────────────────────\u001b[0m\r\n\u001b[94m│\u001b[0m\u001b[1;36m \u001b[0m\u001b[1;36mPragmatist      \u001b[0m\u001b[1;36m \u001b[0m\u001b[94m│\u001b[0m\u001b[2m \u001b[0m\u001b[2mCOO                 \u001b[0m\u001b[2m \u001b[0m\u001b[94m│\u001b[0m \u001b[94mqwen3.5-plus\u001b[0m     \u001b[94m│\u001b[0m  \u001b[1;32mAPPROVE\u001b[0m  \u001b[94m│\u001b[0m \u001b[33m██████░░░░\u001b[0m 68% \u001b[94m│\u001b[0m Team capacity available with schedule trade-off \r\n\u001b[94m└──────────────────┴──────────────────────┴──────────────────┴───────────┴────────────────┴─────────────────────────────────────────────────\u001b[0m\r\n"]
